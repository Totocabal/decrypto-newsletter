# Configuration Supabase — récupère ces valeurs dans Supabase :
# Project Settings → API → "Project URL" et "anon public" key
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# URL vers laquelle les emails Supabase doivent renvoyer.
# Cette URL doit aussi être autorisée dans Supabase Authentication → URL Configuration.
VITE_AUTH_REDIRECT_URL=https://decrypto-newsletter.vercel.app/

# Serveur uniquement: ne jamais préfixer la clé Braze par VITE_.
# Crée une clé Braze limitée à la permission Media Library > media_library.create.
BRAZE_API_KEY=
BRAZE_BASE_URL=https://rest.fra-01.braze.eu
