# Configuration Supabase — récupère ces valeurs dans Supabase :
# Project Settings → API → "Project URL" et "anon public" key
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Optionnel — URL vers laquelle les emails Supabase doivent renvoyer.
# En local, laisser vide pour utiliser http://localhost:5173 / 127.0.0.1.
# En prod, mettre l'URL exacte autorisée dans Supabase Authentication → URL Configuration.
VITE_AUTH_REDIRECT_URL=
